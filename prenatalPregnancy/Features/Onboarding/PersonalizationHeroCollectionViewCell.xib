        <collectionViewCell opaque="NO" clipsSubviews="NO" multipleTouchEnabled="YES" contentMode="center" reuseIdentifier="PersonalizationHeroCollectionViewCell" id="hero-cell" customClass="PersonalizationHeroCollectionViewCell" customModule="Blooma" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="353" height="214"/>
