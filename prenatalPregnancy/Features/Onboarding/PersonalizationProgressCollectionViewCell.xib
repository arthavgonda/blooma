        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell opaque="NO" multipleTouchEnabled="YES" contentMode="center" reuseIdentifier="PersonalizationProgressCollectionViewCell" id="progress-cell" customClass="PersonalizationProgressCollectionViewCell" customModule="Blooma" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="353" height="96"/>
            <autoresizingMask key="autoresizingMask"/>
            <collectionViewCellContentView key="contentView" opaque="NO" multipleTouchEnabled="YES" contentMode="center" id="progress-content">
                <rect key="frame" x="0.0" y="0.0" width="353" height="96"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <visualEffectView opaque="NO" contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="progress-card">
                        <rect key="frame" x="0.0" y="0.0" width="353" height="96"/>
                        <view key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleToFill" id="progress-card-content">
                            <rect key="frame" x="0.0" y="0.0" width="353" height="96"/>
                            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                            <subviews>
                                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Journey Progress" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="progress-title">
                                    <rect key="frame" x="20" y="18" width="147.66666666666666" height="22"/>
                                    <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="18"/>
                                    <nil key="highlightedColor"/>
                                </label>
                                <label opaque="NO" userInteractionEnabled="NO" contentMode="right" horizontalHuggingPriority="249" text="17% Complete" textAlignment="right" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="progress-percent">
                                    <rect key="frame" x="177.66666666666663" y="20.666666666666668" width="155.33333333333337" height="18.000000000000004"/>
                                    <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="15"/>
                                    <color key="textColor" systemColor="secondaryLabelColor"/>
                                    <nil key="highlightedColor"/>
                                </label>
                                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Step 1 of 6" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="progress-step">
                                    <rect key="frame" x="20" y="44" width="313" height="17"/>
                                    <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                    <color key="textColor" systemColor="secondaryLabelColor"/>
                                    <nil key="highlightedColor"/>
                                </label>
                                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="progress-track">
                                    <rect key="frame" x="20" y="69" width="313" height="12"/>
                                    <subviews>
                                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="progress-fill">
                                            <rect key="frame" x="0.0" y="0.0" width="0.0" height="12"/>
                                            <color key="backgroundColor" systemColor="systemPinkColor"/>
                                        </view>
                                    </subviews>
                                    <color key="backgroundColor" white="1" alpha="0.45000000000000001" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    <constraints>
                                        <constraint firstAttribute="bottom" secondItem="progress-fill" secondAttribute="bottom" id="fill-bottom"/>
                                        <constraint firstItem="progress-fill" firstAttribute="leading" secondItem="progress-track" secondAttribute="leading" id="fill-leading"/>
                                        <constraint firstItem="progress-fill" firstAttribute="top" secondItem="progress-track" secondAttribute="top" id="fill-top"/>
                                        <constraint firstItem="progress-fill" firstAttribute="width" id="fill-width"/>
