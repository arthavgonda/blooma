                                <constraint firstItem="progress-track" firstAttribute="top" secondItem="progress-step" secondAttribute="bottom" constant="8" id="track-top"/>
                                <constraint firstAttribute="trailing" secondItem="progress-track" secondAttribute="trailing" constant="20" id="track-trailing"/>
