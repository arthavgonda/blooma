                                <constraint firstItem="progress-percent" firstAttribute="leading" secondItem="progress-title" secondAttribute="trailing" constant="10" id="percent-leading"/>
                                <constraint firstAttribute="trailing" secondItem="progress-percent" secondAttribute="trailing" constant="20" id="percent-trailing"/>
                                <constraint firstItem="progress-step" firstAttribute="leading" secondItem="progress-title" secondAttribute="leading" id="step-leading"/>
                                <constraint firstItem="progress-step" firstAttribute="top" secondItem="progress-title" secondAttribute="bottom" constant="4" id="step-top"/>
                                <constraint firstItem="progress-step" firstAttribute="trailing" secondItem="progress-percent" secondAttribute="trailing" id="step-trailing"/>
                                <constraint firstItem="progress-title" firstAttribute="leading" secondItem="progress-card-content" secondAttribute="leading" constant="20" id="title-leading"/>
                                <constraint firstItem="progress-title" firstAttribute="top" secondItem="progress-card-content" secondAttribute="top" constant="18" id="title-top"/>
