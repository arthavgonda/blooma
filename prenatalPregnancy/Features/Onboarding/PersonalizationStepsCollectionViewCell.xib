<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23504" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23506"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell opaque="NO" clipsSubviews="NO" multipleTouchEnabled="YES" contentMode="center" reuseIdentifier="PersonalizationStepsCollectionViewCell" id="step-cell" customClass="PersonalizationStepsCollectionViewCell" customModule="Blooma" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="353" height="92"/>
            <autoresizingMask key="autoresizingMask"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="NO" multipleTouchEnabled="YES" contentMode="center" id="step-content">
                <rect key="frame" x="0.0" y="0.0" width="353" height="92"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <visualEffectView opaque="NO" clipsSubviews="NO" contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="step-card">
                        <rect key="frame" x="2" y="2" width="349" height="88"/>
                        <view key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleToFill" id="step-card-content">
                            <rect key="frame" x="0.0" y="0.0" width="349" height="88"/>
                            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                            <subviews>
                                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="step-icon-shell">
                                    <rect key="frame" x="18" y="20" width="48" height="48"/>
                                    <subviews>
                                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="step-icon">
                                            <rect key="frame" x="12" y="12" width="24" height="24"/>
                                        </imageView>
                                    </subviews>
                                    <color key="backgroundColor" white="1" alpha="0.45" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    <constraints>
                                        <constraint firstItem="step-icon" firstAttribute="centerX" secondItem="step-icon-shell" secondAttribute="centerX" id="icon-cx"/>
                                        <constraint firstItem="step-icon" firstAttribute="centerY" secondItem="step-icon-shell" secondAttribute="centerY" id="icon-cy"/>
                                        <constraint firstItem="step-icon" firstAttribute="width" constant="24" id="icon-w"/>
                                        <constraint firstItem="step-icon" firstAttribute="height" constant="24" id="icon-h"/>
                                    </constraints>
                                </view>
                                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Analyzing Activities" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="1" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="step-title">
                                    <rect key="frame" x="82" y="22" width="210" height="25"/>
                                    <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="20"/>
                                    <color key="textColor" systemColor="labelColor"/>
                                    <nil key="highlightedColor"/>
                                </label>
                                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Activity types selected" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="1" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="step-subtitle">
                                    <rect key="frame" x="82" y="51" width="210" height="19"/>
                                    <fontDescription key="fontDescription" type="system" pointSize="15"/>
                                    <color key="textColor" systemColor="secondaryLabelColor"/>
                                    <nil key="highlightedColor"/>
                                </label>
                                <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="step-state">
                                    <rect key="frame" x="307" y="32" width="28" height="28"/>
                                </imageView>
                            </subviews>
                            <constraints>
                                <constraint firstItem="step-icon-shell" firstAttribute="leading" secondItem="step-card-content" secondAttribute="leading" constant="18" id="shell-leading"/>
                                <constraint firstItem="step-icon-shell" firstAttribute="centerY" secondItem="step-card-content" secondAttribute="centerY" id="shell-cy"/>
                                <constraint firstItem="step-icon-shell" firstAttribute="width" constant="48" id="shell-w"/>
                                <constraint firstItem="step-icon-shell" firstAttribute="height" constant="48" id="shell-h"/>
                                <constraint firstItem="step-title" firstAttribute="leading" secondItem="step-icon-shell" secondAttribute="trailing" constant="16" id="title-leading"/>
                                <constraint firstItem="step-title" firstAttribute="top" secondItem="step-card-content" secondAttribute="top" constant="22" id="title-top"/>
                                <constraint firstItem="step-subtitle" firstAttribute="leading" secondItem="step-title" secondAttribute="leading" id="subtitle-leading"/>
                                <constraint firstItem="step-subtitle" firstAttribute="top" secondItem="step-title" secondAttribute="bottom" constant="4" id="subtitle-top"/>
                                <constraint firstItem="step-state" firstAttribute="leading" relation="greaterThanOrEqual" secondItem="step-title" secondAttribute="trailing" constant="10" id="state-gap"/>
                                <constraint firstAttribute="trailing" secondItem="step-state" secondAttribute="trailing" constant="14" id="state-trailing"/>
                                <constraint firstItem="step-state" firstAttribute="centerY" secondItem="step-card-content" secondAttribute="centerY" id="state-cy"/>
                                <constraint firstItem="step-state" firstAttribute="width" constant="28" id="state-w"/>
                                <constraint firstItem="step-state" firstAttribute="height" constant="28" id="state-h"/>
                                <constraint firstItem="step-title" firstAttribute="trailing" secondItem="step-state" secondAttribute="leading" constant="-10" id="title-trailing"/>
                                <constraint firstItem="step-subtitle" firstAttribute="trailing" secondItem="step-title" secondAttribute="trailing" id="subtitle-trailing"/>
                            </constraints>
                        </view>
                        <blurEffect style="systemUltraThinMaterialLight"/>
                    </visualEffectView>
                </subviews>
                <constraints>
                    <constraint firstItem="step-card" firstAttribute="top" secondItem="step-content" secondAttribute="top" constant="2" id="card-top"/>
                    <constraint firstItem="step-card" firstAttribute="leading" secondItem="step-content" secondAttribute="leading" constant="2" id="card-leading"/>
                    <constraint firstAttribute="trailing" secondItem="step-card" secondAttribute="trailing" constant="2" id="card-trailing"/>
                    <constraint firstAttribute="bottom" secondItem="step-card" secondAttribute="bottom" constant="2" id="card-bottom"/>
                </constraints>
            </collectionViewCellContentView>
            <connections>
                <outlet property="cardContainer" destination="step-card" id="out-card"/>
                <outlet property="iconImageView" destination="step-icon" id="out-icon"/>
                <outlet property="iconShellView" destination="step-icon-shell" id="out-shell"/>
                <outlet property="stateImageView" destination="step-state" id="out-state"/>
                <outlet property="subtitleLabel" destination="step-subtitle" id="out-sub"/>
                <outlet property="titleLabel" destination="step-title" id="out-title"/>
            </connections>
            <point key="canvasLocation" x="138" y="98"/>
        </collectionViewCell>
    </objects>
    <resources>
        <systemColor name="labelColor">
            <color white="0.0" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
        </systemColor>
        <systemColor name="secondaryLabelColor">
            <color red="0.23529411764705882" green="0.23529411764705882" blue="0.2627450980392157" alpha="0.6" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
    </resources>
</document>
